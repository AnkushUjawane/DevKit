{
  "name": "devkit-wsl",
  "version": "2.0.0",
  "description": "One command to set up your entire dev environment — Docker, Python, Node, Go, Rust, kubectl & more.",
  "author": "Ankush Ujawane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnkushUjawane/DevKit.git"
  },
  "type": "module",
  "bin": {
    "devkit": "./dist/cli.js"
  },
  "scripts": {
    "build":           "tsc",
    "dev":             "tsx src/cli.tsx",
    "clean":           "rm -rf dist",
    "prepublishOnly":  "npm run clean && npm run build"
  },
  "dependencies": {
    "ink":          "^4.4.1",
    "ink-spinner":  "^5.0.0",
    "react":        "^18.2.0",
    "execa":        "^8.0.1",
    "chalk":        "^5.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/node":  "^20.0.0",
    "typescript":   "^5.3.0",
    "tsx":          "^4.7.0"
  },
  "engines": { "node": ">=18.0.0" },
  "files": ["dist/", "README.md", "LICENSE"]
}
