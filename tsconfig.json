{
  "compilerOptions": {
    "target":             "ES2022",
    "module":             "ESNext",
    "moduleResolution":   "bundler",
    "types":              ["node"],
    "jsx":                "react",
    "jsxFactory":         "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    "outDir":             "./dist",
    "rootDir":            "./src",
    "strict":             true,
    "esModuleInterop":    true,
    "skipLibCheck":       true,
    "declaration":        true,
    "sourceMap":          true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
